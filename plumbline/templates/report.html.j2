<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Plumbline — {{ meta.segment_id }}</title>
<style>
  :root{
    --bg:#f6f2e7; --panel:#fdfbf4; --ink:#191813; --muted:#75715f;
    --hair:#ddd6c1; --line:#191813;
    --f-orient:#e23227; --f-spacing:#fcf151; --f-garble:#5acbfa;
    --f-seam:#a855f7; --good:#8efc4e;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--ink);
       font:400 15px/1.55 "Avenir Next", Avenir, "Helvetica Neue", sans-serif;
       -webkit-font-smoothing:antialiased}
  .frame{max-width:1280px;margin:0 auto;padding:0 28px 44px}
  /* ---------- header band ---------- */
  header{border-bottom:1px solid var(--line)}
  .hrow{display:flex;min-height:80px;flex-wrap:wrap}
  .cell{padding:18px 22px;border-left:1px solid var(--hair);
        display:flex;flex-direction:column;justify-content:center}
  .cell:first-child{border-left:0;padding-left:0}
  .k{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);
     font-weight:600;margin-bottom:4px}
  .v{font-size:15px;font-weight:500;font-variant-numeric:tabular-nums}
  .logo{font-size:15px;font-weight:700;letter-spacing:.24em;text-transform:uppercase}
  .logo small{display:block;font-weight:400;letter-spacing:.1em;color:var(--muted);
              font-size:11px;margin-top:4px;text-transform:none}
  /* ---------- layout ---------- */
  main{display:grid;grid-template-columns:minmax(0,1fr) 308px;gap:20px;
       align-items:start;margin-top:20px}
  .panel{background:var(--panel);border:1px solid var(--hair)}
  .viewer{padding:16px 16px 18px}
  /* segmented control (keeps .tabs button.active JS contract) */
  .tabs{display:inline-flex;background:#e9e3d2;border-radius:9px;padding:3px;
        margin-bottom:14px;vertical-align:middle}
  .tabs button{appearance:none;border:0;background:transparent;color:var(--muted);
               padding:6px 15px;font:inherit;font-size:13.5px;border-radius:7px;cursor:pointer}
  .tabs button.active{background:var(--panel);color:var(--ink);font-weight:600;
                      box-shadow:0 1px 2px rgba(25,24,19,.12)}
  .ovl{display:none;margin-left:14px;color:var(--muted);font-size:12.5px;
       cursor:pointer;vertical-align:middle}
  .ovl input{vertical-align:middle;margin-right:5px;accent-color:var(--ink)}
  /* notices */
  .seam-banner,.warning{font-size:13.5px;margin:0 0 12px;padding:2px 0 2px 12px}
  .seam-banner{border-left:3px solid var(--f-seam);font-weight:600}
  .warning{border-left:3px solid var(--ink);color:#54503f}
  .warning b{font-weight:600}
  /* views */
  .viewer .view{display:none}
  .viewer .view.active{display:block}
  .viewer img{width:100%;display:block}
  #ink{position:relative}
  .flagbox{position:absolute;border:2.5px solid;box-sizing:border-box;cursor:help}
  .flagbox.orientation{border-color:var(--f-orient)}
  .flagbox.spacing{border-color:var(--f-spacing)}
  .flagbox.garble{border-color:var(--f-garble)}
  .flagbox.seam{border-color:var(--f-seam)}
  .flagbox:hover,.flagbox.hot{background:rgba(253,251,244,.16);z-index:4}
  .flagbox.hot{box-shadow:0 0 0 2px rgba(253,251,244,.5)}
  .flagbox.glow{background:rgba(253,251,244,.10);z-index:3}
  .flagbox .tip{display:none;position:absolute;left:0;top:100%;z-index:6;
                background:var(--panel);color:var(--ink);padding:5px 9px;
                font-size:11.5px;white-space:nowrap;border:1px solid var(--hair);
                box-shadow:0 2px 8px rgba(25,24,19,.14)}
  .flagbox:hover .tip{display:block}
  .cap{font-size:12.5px;color:var(--muted);margin-top:11px;min-height:34px}
  .cap b{color:var(--ink);font-weight:600}
  /* ---------- rail ---------- */
  .health{padding:20px 20px 16px}
  .health .n{font-size:62px;font-weight:200;letter-spacing:-.03em;line-height:1}
  .health .n small{font-size:21px;color:var(--muted);font-weight:300}
  .health .lbl{font-size:11.5px;letter-spacing:.18em;text-transform:uppercase;
               color:var(--muted);font-weight:600;margin-top:8px}
  .bar{height:3px;background:var(--hair);margin-top:14px;overflow:hidden;border-radius:2px}
  .bar i{display:block;height:100%}
  .list{padding:2px 20px 6px}
  .row{display:grid;grid-template-columns:16px 1fr auto;gap:10px;align-items:center;
       padding:11px 0;border-top:1px solid var(--hair);font-size:14px;cursor:help}
  .row b{font-variant-numeric:tabular-nums;font-weight:600;font-size:15px}
  .row .z{color:var(--muted);font-weight:400}
  .led{width:9px;height:9px;border-radius:50%;border:1px solid rgba(25,24,19,.40)}
  .led.or{background:var(--f-orient)} .led.sp{background:var(--f-spacing)}
  .led.ga{background:var(--f-garble)} .led.se{background:var(--f-seam)}
  .led.off{background:#cfc8b2;border-color:rgba(25,24,19,.22)}
  .params{padding:13px 20px 16px;border-top:1px solid var(--hair);
          font-size:12px;color:var(--muted);line-height:1.8}
  .params b{color:var(--ink);font-weight:500;font-variant-numeric:tabular-nums}
  /* ---------- regions ---------- */
  .regions{grid-column:1/-1;padding:16px 20px 8px}
  .regions h3{font-size:10.5px;font-weight:600;letter-spacing:.2em;
              text-transform:uppercase;color:var(--muted);margin-bottom:8px}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);
     font-weight:600;text-align:left;padding:8px;border-bottom:1px solid var(--line)}
  td{padding:9px 8px;border-bottom:1px solid var(--hair);font-variant-numeric:tabular-nums}
  tr:last-child td{border-bottom:0}
  td .led{display:inline-block;margin-right:9px;vertical-align:0}
  td.mode{font-weight:600;font-size:13.5px}
  tr.regrow{cursor:pointer}
  tr.regrow:hover{background:#f4efdf}
  @media(max-width:900px){main{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="frame">

<header>
  <div class="hrow">
    <div class="cell"><div class="logo">Plumbline<small>trace-quality report</small></div></div>
    <div class="cell"><div class="k">Scroll</div><div class="v">{{ meta.scroll }}</div></div>
    <div class="cell"><div class="k">Segment</div><div class="v">{{ meta.segment_id }}</div></div>
    <div class="cell"><div class="k">Raster</div><div class="v">{{ "{:,}".format(iw) }} × {{ "{:,}".format(ih) }} px</div></div>
    <div class="cell"><div class="k">Analyzed</div><div class="v">{{ analyzed }}</div></div>
  </div>
</header>

<main>

  <div class="panel viewer">
    <div>
      <div class="tabs">
        <button data-view="ink" class="active" onclick="show('ink')">Ink + flags</button>
        <button data-view="heat" onclick="show('heat')">Coherence</button>
        <button data-view="orient" onclick="show('orient')">Orientation</button>
        <button data-view="flags" onclick="show('flags')">Flags</button>
      </div><label class="ovl" id="ovlwrap"><input type="checkbox" id="ovlchk" onchange="toggleOverlay()">overlay ink image</label>
    </div>
    {% if report.n_seam %}<p class="seam-banner">⚠ Sheet-jump seam detected — text rows step vertically at a column; the area-based score barely moves, so this banner is the signal.</p>{% endif %}
    {% if warning %}<p class="warning"><b>Note</b> — {{ warning }}</p>{% endif %}
    <div id="ink" class="view active">
      <img src="data:image/png;base64,{{ img_ink }}">
      {% for r in regions %}
      <div class="flagbox {{ r.mode }}" id="fb{{ loop.index0 }}"
           style="left:{{ '%.3f' % (100.0 * r.x0 / iw) }}%;top:{{ '%.3f' % (100.0 * r.y0 / ih) }}%;width:{{ '%.3f' % (100.0 * (r.x1 - r.x0) / iw) }}%;height:{{ '%.3f' % (100.0 * (r.y1 - r.y0) / ih) }}%"><span class="tip">{{ r.mode }} · {{ r.detail }}</span></div>
      {% endfor %}
    </div>
    <img id="heat" class="view" data-plain="data:image/png;base64,{{ img_heat }}" data-over="data:image/png;base64,{{ img_heat_over }}" src="data:image/png;base64,{{ img_heat }}">
    <img id="orient" class="view" data-plain="data:image/png;base64,{{ img_orient }}" data-over="data:image/png;base64,{{ img_orient_over }}" src="data:image/png;base64,{{ img_orient }}">
    <img id="flags" class="view" src="data:image/png;base64,{{ img_flags }}">
    <div id="cap" class="cap"></div>
  </div>

  <div class="panel">
    <div class="health">
      <div class="n">{{ report.score }}<small> /100</small></div>
      <div class="lbl">Trace health</div>
      <div class="bar"><i style="width:{{ report.score }}%;background:{{ score_color }}"></i></div>
    </div>
    <div class="list">
      <div class="row" title="Tiles whose text-row direction departs from the local consensus — a sheet jump, drift, or rotation. Lower is better; 0 = consistent rows."><span class="led {{ 'or' if report.n_orient else 'off' }}"></span><span>Orientation breaks</span><b{% if not report.n_orient %} class="z"{% endif %}>{{ report.n_orient }}</b></div>
      <div class="row" title="Tiles whose row spacing departs from the local median — lines bunching or stretching. Lower is better."><span class="led {{ 'sp' if report.n_spacing else 'off' }}"></span><span>Spacing breaks</span><b{% if not report.n_spacing %} class="z"{% endif %}>{{ report.n_spacing }}</b></div>
      <div class="row" title="Confident-ink tiles with no row structure — mottle/noise rather than text. Lower is better."><span class="led {{ 'ga' if report.n_garble else 'off' }}"></span><span>Garble</span><b{% if not report.n_garble %} class="z"{% endif %}>{{ report.n_garble }}</b></div>
      <div class="row" title="Tiles straddling a vertical seam where text rows step up/down without rotating or changing spacing — the fingerprint of a sheet jump. Lower is better."><span class="led {{ 'se' if report.n_seam else 'off' }}"></span><span>Seam breaks</span><b{% if not report.n_seam %} class="z"{% endif %}>{{ report.n_seam }}</b></div>
      <div class="row" title="Share of tiles with too little ink to assess (mostly blank background). NOT a quality score — high just means lots of empty area, normal for sparse text."><span></span><span>Low-confidence area</span><b>{{ '%.0f' % (report.low_conf_frac * 100) }}%</b></div>
    </div>
    <div class="params">
      tile <b>{{ tile_px }} px</b>{% if gpitch_px %} · global pitch <b>{{ '%.0f' % gpitch_px }} px</b>{% endif %}<br>
      skew <b>{{ '%.1f' % gtheta_deg }}°</b> · plumbline <b>{{ version }}</b>
    </div>
  </div>

  <div class="panel regions">
    <h3>Flagged regions</h3>
    <table>
      <tr><th>x</th><th>y</th><th>mode</th><th>measurements</th></tr>
      {% for r in regions %}<tr class="regrow" data-idx="{{ loop.index0 }}" title="click to locate"><td>{{ "{:,}".format(r.x) }}</td><td>{{ "{:,}".format(r.y) }}</td><td class="mode"><span class="led {{ {'orientation':'or','spacing':'sp','garble':'ga','seam':'se'}[r.mode] }}"></span>{{ r.mode }}</td><td style="color:var(--muted);font-size:13px">{{ r.detail }}</td></tr>{% endfor %}
    </table>
  </div>

</main>

</div>
<script>
const CAPS = {
  ink: "Ink prediction with every flagged tile outlined (color = failure mode). <b>Hover a box for that tile's measurements</b>; click a row in the Flagged-regions table to jump to its box. More flags means a lower score.",
  heat: "<b>Row coherence</b> per confident tile: bright = ink forms clear text rows. Near-empty / very sparse tiles are <b>dimmed</b> (not blacked out) so a lone ink sliver doesn't read brighter than real text — a dim tile can mean weak structure <i>or</i> just little ink, so cross-check the Flags view. Background (too little ink to assess) is left blank. Tick <b>overlay ink image</b> to read it against the text. Banded papyrus fibers can mimic rows, so high coherence is <b>not</b> proof of ink.",
  orient: "Dominant text-row axis per confident tile (ticks lie along the rows; orientation is measured mod 180° — the analyzer cannot know the reading direction, so no arrowheads). Tick <b>overlay ink image</b> to see them against the text they describe. A local break here is flagged as an orientation break.",
  flags: "Flagged tiles by failure mode — orientation (red) · spacing (lemon) · garble (sky) · seam (purple — rows step at a sheet jump). Tiles span the analysis grid (not individual letters)."
};
const OVERLAYABLE = {heat:1, orient:1};   // tabs that support the ink overlay toggle
function applyOverlay(id){
  const img=document.getElementById(id);
  if(!img || !img.dataset.over) return;
  img.src = document.getElementById('ovlchk').checked ? img.dataset.over : img.dataset.plain;
}
function show(id){
  document.querySelectorAll('.viewer .view').forEach(i=>i.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.tabs button').forEach(b=>b.classList.toggle('active', b.dataset.view===id));
  document.getElementById('ovlwrap').style.display = OVERLAYABLE[id] ? 'inline-block' : 'none';
  if(OVERLAYABLE[id]) applyOverlay(id);            // honor the checkbox on this tab
  document.getElementById('cap').innerHTML = CAPS[id];
}
function toggleOverlay(){
  applyOverlay('heat'); applyOverlay('orient');    // keep both overlay tabs in sync
}
document.querySelectorAll('tr.regrow').forEach(function(tr){
  var box = function(){ return document.getElementById('fb' + tr.dataset.idx); };
  tr.addEventListener('click', function(){
    show('ink');                                   // boxes live on the ink view
    var b = box();
    if(!b) return;
    b.classList.add('hot');
    b.scrollIntoView({block:'center', behavior:'smooth'});
    setTimeout(function(){ b.classList.remove('hot'); }, 1600);
  });
  // hovering the row gives its box a faint glow (no scroll -- click locates)
  tr.addEventListener('mouseenter', function(){ var b = box(); if(b) b.classList.add('glow'); });
  tr.addEventListener('mouseleave', function(){ var b = box(); if(b) b.classList.remove('glow'); });
});
show('ink');
</script>
</body>
</html>
