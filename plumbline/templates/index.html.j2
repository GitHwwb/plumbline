<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Plumbline — {{ meta.scroll }}</title>
<style>
  :root{
    --bg:#f6f2e7; --panel:#fdfbf4; --ink:#191813; --muted:#75715f;
    --hair:#ddd6c1; --line:#191813;
    --f-orient:#e23227; --f-spacing:#fcf151; --f-garble:#5acbfa;
    --f-seam:#a855f7; --good:#8efc4e;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--ink);
       font:400 15px/1.55 "Avenir Next", Avenir, "Helvetica Neue", sans-serif;
       -webkit-font-smoothing:antialiased}
  .frame{max-width:1280px;margin:0 auto;padding:0 28px 44px}
  /* ---------- header band ---------- */
  header{border-bottom:1px solid var(--line)}
  .hrow{display:flex;min-height:80px;flex-wrap:wrap}
  .cell{padding:18px 22px;border-left:1px solid var(--hair);
        display:flex;flex-direction:column;justify-content:center}
  .cell:first-child{border-left:0;padding-left:0}
  .k{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);
     font-weight:600;margin-bottom:4px}
  .v{font-size:15px;font-weight:500;font-variant-numeric:tabular-nums}
  .logo{font-size:15px;font-weight:700;letter-spacing:.24em;text-transform:uppercase}
  .logo small{display:block;font-weight:400;letter-spacing:.1em;color:var(--muted);
              font-size:11px;margin-top:4px;text-transform:none}
  /* ---------- toolbar + table ---------- */
  .toolbar{margin:20px 0 14px}
  #q{width:min(420px,100%);padding:8px 12px;background:var(--panel);color:var(--ink);
     border:1px solid var(--hair);font:inherit;font-size:14px}
  #q::placeholder{color:var(--muted)}
  .panel{background:var(--panel);border:1px solid var(--hair)}
  table{width:100%;border-collapse:collapse}
  th,td{text-align:left;padding:9px 14px;font-size:14px}
  thead th{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;
           color:var(--muted);font-weight:600;border-bottom:1px solid var(--line);
           cursor:pointer;user-select:none;white-space:nowrap}
  tbody td{border-bottom:1px solid var(--hair);font-variant-numeric:tabular-nums}
  tbody tr:last-child td{border-bottom:0}
  tr.clickable{cursor:pointer}
  tr.clickable:hover{background:#f4efdf}
  .thumb{width:52px;height:32px;object-fit:cover;border:1px solid var(--hair);display:block}
  .badge{display:inline-block;min-width:44px;text-align:center;color:var(--ink);
         padding:2px 8px;font-weight:600;border:1px solid rgba(25,24,19,.40)}
  .seam-badge{background:var(--f-seam);color:var(--ink);padding:2px 7px;
              border:1px solid rgba(25,24,19,.40);font-size:10px;font-weight:700;
              letter-spacing:.08em;margin-left:8px;text-transform:uppercase;
              vertical-align:1px}
  .err{color:var(--f-orient);font-size:11.5px;font-weight:600}
  .muted{color:var(--muted)}
  .led{display:inline-block;width:9px;height:9px;border-radius:50%;
       border:1px solid rgba(25,24,19,.40);margin-right:8px;vertical-align:0}
  .led.off{background:#cfc8b2;border-color:rgba(25,24,19,.22)}
</style>
</head>
<body>
<div class="frame">

<header>
  <div class="hrow">
    <div class="cell"><div class="logo">Plumbline<small>trace-quality dashboard</small></div></div>
    <div class="cell"><div class="k">Scroll</div><div class="v">{{ meta.scroll }}</div></div>
    <div class="cell"><div class="k">Segments</div><div class="v">{{ n_total }}</div></div>
    <div class="cell"><div class="k">Flagged</div><div class="v">{{ n_flagged }}</div></div>
    {% if n_errors %}<div class="cell"><div class="k">Errors</div><div class="v">{{ n_errors }}</div></div>{% endif %}
  </div>
</header>

<div class="toolbar"><input id="q" placeholder="search segments…" oninput="filt()"></div>

<div class="panel">
<table id="t">
<thead><tr>
  <th>view</th>
  <th onclick="sortBy(1,'s')">segment</th>
  <th onclick="sortBy(2,'n')">health</th>
  <th onclick="sortBy(3,'n')">orient</th>
  <th onclick="sortBy(4,'n')">spacing</th>
  <th onclick="sortBy(5,'n')">garble</th>
  <th onclick="sortBy(6,'n')">seam</th>
  <th onclick="sortBy(7,'n')">low-conf</th>
</tr></thead>
<tbody>
{% for r in rows %}
<tr data-id="{{ r.seg_id }}"{% if r.report_filename and not r.error %} class="clickable" data-href="{{ r.report_filename }}"{% endif %}>
  <td>{% if r.thumb_b64 %}<img class="thumb" src="data:image/png;base64,{{ r.thumb_b64 }}">{% endif %}</td>
  <td>{{ r.seg_id }}{% if r.error %} <span class="err">not evaluated</span>{% endif %}{% if r.n_seam %} <span class="seam-badge" title="text rows step vertically at a column — the fingerprint of a sheet jump; the score barely moves, so seam segments sort to the top">seam</span>{% endif %}</td>
  <td data-v="{{ r.score }}"><span class="badge" style="background:{{ score_color(r.score) }}">{{ r.score }}</span></td>
  <td data-v="{{ r.n_orient }}"><span class="led {{ 'on' if r.n_orient else 'off' }}"{% if r.n_orient %} style="background:var(--f-orient)"{% endif %}></span>{% if r.n_orient %}{{ r.n_orient }}{% else %}<span class="muted">0</span>{% endif %}</td>
  <td data-v="{{ r.n_spacing }}"><span class="led {{ 'on' if r.n_spacing else 'off' }}"{% if r.n_spacing %} style="background:var(--f-spacing)"{% endif %}></span>{% if r.n_spacing %}{{ r.n_spacing }}{% else %}<span class="muted">0</span>{% endif %}</td>
  <td data-v="{{ r.n_garble }}"><span class="led {{ 'on' if r.n_garble else 'off' }}"{% if r.n_garble %} style="background:var(--f-garble)"{% endif %}></span>{% if r.n_garble %}{{ r.n_garble }}{% else %}<span class="muted">0</span>{% endif %}</td>
  <td data-v="{{ r.n_seam }}"><span class="led {{ 'on' if r.n_seam else 'off' }}"{% if r.n_seam %} style="background:var(--f-seam)"{% endif %}></span>{% if r.n_seam %}{{ r.n_seam }}{% else %}<span class="muted">0</span>{% endif %}</td>
  <td data-v="{{ r.low_conf_frac }}" class="muted">{{ '%.0f' % (r.low_conf_frac * 100) }}%</td>
</tr>
{% endfor %}
</tbody>
</table>
</div>

</div>
<script>
function filt(){
  var q = document.getElementById('q').value.toLowerCase();
  document.querySelectorAll('#t tbody tr').forEach(function(tr){
    tr.style.display = tr.getAttribute('data-id').toLowerCase().indexOf(q) >= 0 ? '' : 'none';
  });
}
document.querySelector('#t tbody').addEventListener('click', function(e){
  var tr = e.target.closest('tr');
  if (tr && tr.dataset.href) location.href = tr.dataset.href;
});
var asc = {2: true};  // health already rendered ascending; first click flips to best-first
function sortBy(col, type){
  var tb = document.querySelector('#t tbody');
  var rows = Array.prototype.slice.call(tb.querySelectorAll('tr'));
  asc[col] = !asc[col];
  var dir = asc[col] ? 1 : -1;
  rows.sort(function(a, b){
    var av, bv;
    if (type === 'n'){
      av = parseFloat(a.children[col].getAttribute('data-v'));
      bv = parseFloat(b.children[col].getAttribute('data-v'));
    } else {
      av = a.getAttribute('data-id');   // clean seg_id, excludes "not evaluated" text
      bv = b.getAttribute('data-id');
    }
    return av < bv ? -dir : av > bv ? dir : 0;
  });
  rows.forEach(function(r){ tb.appendChild(r); });
}
</script>
</body>
</html>
